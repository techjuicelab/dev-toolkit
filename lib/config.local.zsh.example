#!/bin/zsh
# ─────────────────────────────────────────────────────
# config.local.zsh - 사용자 개인 설정 (예시)
# 이 파일을 config.local.zsh로 복사하여 사용하세요.
# 이 파일은 git에 추적되지 않습니다.
# ─────────────────────────────────────────────────────

# ─── 색상 커스터마이징 예시 ─────────────────────────
# COLOR_GREEN=$'\e[38;5;82m'    # 더 밝은 초록색
# COLOR_CYAN=$'\e[38;5;87m'     # 더 밝은 시안

# ─── 진행 바 스타일 변경 ───────────────────────────
# BAR_FILLED=$'█'
# BAR_EMPTY=$'░'

# ─── 로그 설정 변경 ────────────────────────────────
# LOG_RETENTION_DAYS=30          # 로그 보관 기간 (기본: 7일)
# LOG_MAX_FILES=50               # 최대 로그 파일 수 (기본: 30)

# ─── 타임아웃 설정 ─────────────────────────────────
# COMMAND_TIMEOUT_SECONDS=600    # 명령어 타임아웃 (기본: 300초)
# MAX_RETRIES=5                  # 재시도 횟수 (기본: 3)

# ─── 레이아웃 설정 ─────────────────────────────────
# BOX_WIDTH=60                   # 타이틀 박스 너비 (기본: 52)
# PROGRESS_BAR_LINE=30           # 진행률 바 위치 (기본: 25)

# ─── 병렬 처리 ─────────────────────────────────────
# ASDF_MAX_PARALLEL=8            # asdf 병렬 조회 수 (기본: 4)
